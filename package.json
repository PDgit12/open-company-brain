{
  "name": "open-company-brain",
  "version": "0.7.3",
  "description": "The open-source company brain that powers a closed loop — model-free, over MCP. Your AI tool (Claude, Cursor, Copilot) answers from your docs with citations or refuses; record how-work-gets-done as skills, govern real actions with human approval + an audit trail, and let the loop learn from outcomes. Comb runs no model of its own — bring your own model, data, and infra.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "public",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "comb": "bin/cli.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PDgit12/open-company-brain.git"
  },
  "homepage": "https://github.com/PDgit12/open-company-brain#readme",
  "bugs": {
    "url": "https://github.com/PDgit12/open-company-brain/issues"
  },
  "author": "PDgit12 (https://github.com/PDgit12)",
  "keywords": [
    "rag",
    "knowledge-graph",
    "ai-agents",
    "langbase",
    "ollama",
    "pgvector",
    "self-hosted",
    "glean-alternative",
    "company-knowledge",
    "cite-or-refuse"
  ],
  "scripts": {
    "init": "node bin/cli.mjs init",
    "doctor": "node bin/cli.mjs doctor",
    "dev": "tsx watch src/server/index.ts",
    "start": "node dist/server/index.js",
    "build": "tsc -p tsconfig.json",
    "demo": "COMB_SEED_DEMO=on COMB_DEMO_GENERATION=on tsx src/server/index.ts",
    "setup:live": "tsx src/brain/setup-live.ts",
    "setup:local": "tsx src/brain/setup-local.ts",
    "mcp": "tsx src/mcp/server.ts",
    "run:agent": "tsx src/harness/cli.ts run",
    "chat": "tsx src/harness/cli.ts chat",
    "eval": "tsx src/eval/run.ts",
    "eval:agents": "tsx src/eval/agent-run.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "coverage": "vitest run --coverage --coverage.provider=v8 --coverage.include=src/**",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,json,md}\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "langbase": "^1.1.49",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "@aws-sdk/client-s3vectors": "^3.1068.0",
    "gpt-tokenizer": "^3.4.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3vectors": "^3.1068.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  },
  "license": "MIT"
}
