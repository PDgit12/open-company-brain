{
  "name": "company-brain",
  "version": "0.1.0",
  "description": "An open-source, governed Company Brain: ingests structured records into a semantic recall layer (Langbase Memory) + a foreign-key knowledge graph, and serves grounded, cited briefing & Q&A agents. Bring your own domain, data, and deployment.",
  "type": "module",
  "bin": {
    "company-brain": "bin/cli.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "init": "node bin/cli.mjs init",
    "doctor": "node bin/cli.mjs doctor",
    "dev": "tsx watch src/server/index.ts",
    "start": "node dist/server/index.js",
    "build": "tsc -p tsconfig.json",
    "demo": "tsx src/server/index.ts",
    "setup:live": "tsx src/brain/setup-live.ts",
    "sync": "tsx src/brain/sync.ts",
    "sync:full": "tsx src/brain/sync.ts -- --full",
    "eval": "tsx src/eval/run.ts",
    "seed:db": "tsx src/seed/seed.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,json,md}\""
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "langbase": "^1.1.49",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  },
  "license": "MIT"
}
