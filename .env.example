# ─────────────────────────────────────────────────────────────────────────────
# Company Brain — environment configuration
#
# The service runs in one of four backends (set LLM_BACKEND, or leave it `auto`):
#
#   • MOCK   (default, zero credentials): no LLM_BACKEND/key set → in-memory seed
#     data + a deterministic engine. Clickable and demoable with NO external keys.
#
#   • OPENAI (bring your own key): set OPENAI_API_KEY → any OpenAI-compatible
#     provider (OpenAI, Groq, Together, OpenRouter, LM Studio, vLLM) via
#     OPENAI_BASE_URL. Needs pgvector (VECTOR_DATABASE_URL) for recall.
#
#   • LANGBASE (managed): LLM_BACKEND=langbase (or just set LANGBASE_API_KEY) →
#     real Langbase Memory + Pipes; optionally your Postgres via DATABASE_URL.
#
#   • LOCAL  (self-hosted, $0/query): LLM_BACKEND=local → Ollama generation +
#     Ollama embeddings + a pgvector recall store. See the local block below.
#
# Copy this file to `.env` and fill in only what you need.
# ─────────────────────────────────────────────────────────────────────────────

# --- Server ---
# Default 4000 so it never collides with a Next.js webapp on 3000.
PORT=4000

# --- Bring your own key (OpenAI-compatible; leave blank to stay in MOCK) ---
# Works with OpenAI, Groq, Together, OpenRouter, LM Studio, vLLM — point
# OPENAI_BASE_URL at the provider. Recall needs pgvector (VECTOR_DATABASE_URL).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Vector dimension of the embedding model above (3-small = 1536).
OPENAI_EMBEDDING_DIM=1536

# --- Context window (harness packing) ---
# 0 = DYNAMIC: resolved from the active model (Ollama introspection → known-
# models table → safe 8192 default). Set a positive number to pin it.
COMB_CONTEXT_WINDOW_TOKENS=0

# --- Langbase (leave blank to stay in MOCK mode) ---
# Get a key at https://langbase.com → Settings → API keys
LANGBASE_API_KEY=
# Name of the Langbase Memory that holds the brain (created on first sync).
LANGBASE_MEMORY_NAME=company-brain
# Name of the Langbase Pipe (agent) used for generation in LIVE mode.
LANGBASE_PIPE_NAME=company-brain-agent
# Models for recall (embeddings) + generation. BOTH need a matching provider key
# in your Langbase workspace (Settings → LLM API keys). Defaults use OpenAI.
# Embeddings: openai:text-embedding-3-large | cohere:embed-multilingual-v3.0 | google:text-embedding-004
LANGBASE_EMBEDDING_MODEL=openai:text-embedding-3-large
LANGBASE_GENERATION_MODEL=openai:gpt-4o-mini

# Going live (after setting LANGBASE_API_KEY above):
#   1. Add an OpenAI key in the Langbase dashboard → Settings → LLM API keys
#   2. Run `npm run setup:live`  (provisions the Memory + Pipe, syncs your data)

# --- Fully-local backend (Ollama + pgvector) — $0 per query, self-hosted ---
# Set LLM_BACKEND=local to bypass Langbase entirely: local LLM generation, local
# embeddings, and a pgvector recall store. Requires a running Ollama + a Postgres
# with the pgvector extension (docker compose up -d gives you one).
#   ollama serve && ollama pull llama3.2:1b nomic-embed-text
LLM_BACKEND=auto          # auto | mock | langbase | local
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_GENERATION_MODEL=llama3.2:1b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768                 # must match the embedding model (nomic-embed-text = 768)
RETRIEVAL_MIN_SCORE=0.5           # similarity floor so the brain refuses on weak matches
# Postgres holding the pgvector table (defaults to DATABASE_URL if unset).
# With the bundled `docker compose up -d`, use host port 5433:
#   VECTOR_DATABASE_URL=postgres://brain:brain@localhost:5433/company_brain
VECTOR_DATABASE_URL=

# --- Postgres (optional; powers persistence for langbase mode + the action/agent
#     stores). The local backend uses VECTOR_DATABASE_URL above. ---
# Example: postgres://user:password@localhost:5432/company_brain
DATABASE_URL=

# --- Ingest webhook auth (the data driver: n8n / workflows / apps) ---
# When INGEST_API_KEY is set, POST /api/ingest and POST /api/fanout/agents require
# it (Authorization: Bearer <key>  or  x-api-key), and the caller is granted
# INGEST_SCOPES. Leave blank for open local/mock dev. SET IT for any shared brain.
INGEST_API_KEY=
INGEST_SCOPES=default-team
INGEST_RATE_LIMIT_PER_MIN=120

# --- MCP shell (the agent door) ---
# Access scopes an MCP-connected agent (Claude/Cursor) may read. Point the MCP
# server's env at the SAME store as the API so all shells share one brain.
MCP_SCOPES=default-team

# --- Action delivery (where approved actions go) ---
# outbox (default, record-only) | file (writes outbox/*.jsonl) | webhook (POSTs)
ACTION_DELIVERY=outbox
ACTION_OUTBOX_PATH=outbox
ACTION_WEBHOOK_URL=

# --- Access scope for the demo user (governance) ---
# In a real deployment this comes from your auth layer per request.
DEMO_USER_ACCESS_SCOPE=default-team
