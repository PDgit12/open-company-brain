# ─────────────────────────────────────────────────────────────────────────────
# Company Brain — environment configuration
#
# The service runs in one of two modes, decided automatically by what you set:
#
#   • MOCK mode  (default, zero credentials): if LANGBASE_API_KEY is absent, the
#     brain runs entirely on in-memory seed data with a deterministic retrieval +
#     briefing engine. Everything is clickable and demoable with NO external keys.
#
#   • LIVE mode  (production): set LANGBASE_API_KEY (+ DATABASE_URL) and the brain
#     uses real Langbase Memory + Pipes and reads from your Postgres.
#
# Copy this file to `.env` and fill in only what you need.
# ─────────────────────────────────────────────────────────────────────────────

# --- Server ---
# Default 4000 so it never collides with a Next.js webapp on 3000.
PORT=4000

# --- Langbase (leave blank to stay in MOCK mode) ---
# Get a key at https://langbase.com → Settings → API keys
LANGBASE_API_KEY=
# Name of the Langbase Memory that holds the brain (created on first sync).
LANGBASE_MEMORY_NAME=company-brain
# Name of the Langbase Pipe (agent) used for generation in LIVE mode.
LANGBASE_PIPE_NAME=company-brain-agent
# Models for recall (embeddings) + generation. BOTH need a matching provider key
# in your Langbase workspace (Settings → LLM API keys). Defaults use OpenAI.
# Embeddings: openai:text-embedding-3-large | cohere:embed-multilingual-v3.0 | google:text-embedding-004
LANGBASE_EMBEDDING_MODEL=openai:text-embedding-3-large
LANGBASE_GENERATION_MODEL=openai:gpt-4o-mini

# Going live (after setting LANGBASE_API_KEY above):
#   1. Add an OpenAI key in the Langbase dashboard → Settings → LLM API keys
#   2. Run `npm run setup:live`  (provisions the Memory + Pipe, syncs your data)

# --- Fully-local backend (Ollama + pgvector) — $0 per query, self-hosted ---
# Set LLM_BACKEND=local to bypass Langbase entirely: local LLM generation, local
# embeddings, and a pgvector recall store. Requires a running Ollama + a Postgres
# with the pgvector extension (docker compose up -d gives you one).
#   ollama serve && ollama pull llama3.2:1b nomic-embed-text
LLM_BACKEND=auto          # auto | mock | langbase | local
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_GENERATION_MODEL=llama3.2:1b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768                 # must match the embedding model (nomic-embed-text = 768)
RETRIEVAL_MIN_SCORE=0.5           # similarity floor so the brain refuses on weak matches
# Postgres holding the pgvector table (defaults to DATABASE_URL if unset):
VECTOR_DATABASE_URL=

# --- Data connector (where the brain reads from) ---
# auto (default) = postgres if DATABASE_URL set, else seed data.
# Other options: seed | postgres | csv | json
DATA_CONNECTOR=auto
# For csv: a folder of *.csv files. For json: a snapshot.json file.
# Try the bundled sample:  DATA_CONNECTOR=csv  CONNECTOR_PATH=examples/sample-data
CONNECTOR_PATH=

# --- Postgres (leave blank to use in-memory seed data) ---
# Example: postgres://user:password@localhost:5432/company_brain
DATABASE_URL=

# --- Action delivery (where approved actions go) ---
# outbox (default, record-only) | file (writes outbox/*.jsonl) | webhook (POSTs)
ACTION_DELIVERY=outbox
ACTION_OUTBOX_PATH=outbox
ACTION_WEBHOOK_URL=

# --- Access scope for the demo user (governance) ---
# In a real deployment this comes from your auth layer per request.
DEMO_USER_ACCESS_SCOPE=default-team
